// Secrets.xcconfig — copy to Secrets.xcconfig and gitignore it.
// This file documents all required secret build settings.
// Never commit the real Secrets.xcconfig.

// Stripe publishable key (pk_live_... for production, pk_test_... for dev)
STRIPE_PUBLISHABLE_KEY = pk_test_REPLACE_ME

// Add Secrets.xcconfig to your Debug and Release configurations in
// the Xcode project: Project → Info → Configurations → ▸ Add Config File
// Then set STRIPE_PUBLISHABLE_KEY in Info.plist:
//   <key>STRIPE_PUBLISHABLE_KEY</key>
//   <string>$(STRIPE_PUBLISHABLE_KEY)</string>
